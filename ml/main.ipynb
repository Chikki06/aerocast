    "# Time series analysis for specific locations\n",
    "def analyze_location_trends(forecasts, original_df):\n",
    "    \"\"\"\n",
    "    Analyze trends for specific locations of interest\n",
    "    \"\"\"\n",
    "    # Select a few representative locations\n",
    "    sample_locations = original_df.groupby(['longitude', 'latitude']).size().reset_index(name='count')\n",
    "    sample_locations = sample_locations.nlargest(5, 'count')  # Top 5 locations with most data\n",
    "    \n",
    "    fig, axes = plt.subplots(2, 3, figsize=(18, 10))\n",
    "    axes = axes.flatten()\n",
    "    \n",
    "    for i, (_, location) in enumerate(sample_locations.head(5).iterrows()):\n",
    "        ax = axes[i]\n",
    "        \n",
    "        lon, lat = location['longitude'], location['latitude']\n",
    "        \n",
    "        # Get historical data for this location\n",
    "        location_data = original_df[\n",
    "            (abs(original_df['longitude'] - lon) < 0.1) & \n",
    "            (abs(original_df['latitude'] - lat) < 0.1)\n",
    "        ].sort_values('date')\n",
    "        \n",
    "        # Get forecast data for this location\n",
    "        forecast_series = []\n",
    "        dates = []\n",
    "        \n",
    "        for forecast in forecasts:\n",
    "            # Find closest point in forecast\n",
    "            distances = np.sqrt((forecast['longitude'] - lon)**2 + (forecast['latitude'] - lat)**2)\n",
    "            closest_idx = distances.idxmin()\n",
    "            \n",
    "            forecast_series.append(forecast.loc[closest_idx, 'predicted_no2'])\n",
    "            dates.append(forecast.loc[closest_idx, 'forecast_date'])\n",
    "        \n",
    "        # Plot historical data\n",
    "        if len(location_data) > 0:\n",
    "            ax.plot(location_data['date'], location_data['no2'], 'bo-', \n",
    "                   label='Historical', markersize=4, linewidth=2)\n",
    "        \n",
    "        # Plot forecasts\n",
    "        ax.plot(dates, forecast_series, 'ro-', \n",
    "               label='Forecast', markersize=4, linewidth=2)\n",
    "        \n",
    "        ax.set_title(f'Location: ({lon:.1f}°, {lat:.1f}°)', fontsize=10)\n",
    "        ax.set_xlabel('Date')\n",
    "        ax.set_ylabel('NO₂ Concentration')\n",
    "        ax.legend()\n",
    "        ax.grid(True, alpha=0.3)\n",
    "        ax.tick_params(axis='x', rotation=45)\n",
    "    \n",
    "    # Summary statistics plot\n",
    "    ax = axes[5]\n",
    "    \n",
    "    # Calculate regional statistics\n",
    "    forecast_means = [forecast['predicted_no2'].mean() for forecast in forecasts]\n",
    "    forecast_dates = [forecast['forecast_date'].iloc[0] for forecast in forecasts]\n",
    "    \n",
    "    ax.plot(forecast_dates, forecast_means, 'go-', linewidth=3, markersize=6)\n",
    "    ax.set_title('Regional Average NO₂ Forecast', fontsize=12)\n",
    "    ax.set_xlabel('Date')\n",
    "    ax.set_ylabel('Mean NO₂ Concentration')\n",
    "    ax.grid(True, alpha=0.3)\n",
    "    ax.tick_params(axis='x', rotation=45)\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "# Analyze location trends\n",
    "analyze_location_trends(forecasts, df_clean)"
   ]
