    "# Visualize forecasts\n",
    "def plot_forecast_maps(forecasts, original_data, num_days=3):\n",
    "    \"\"\"\n",
    "    Create maps showing forecasted atmospheric conditions\n",
    "    \"\"\"\n",
    "    fig, axes = plt.subplots(2, num_days, figsize=(5*num_days, 10))\n",
    "    if num_days == 1:\n",
    "        axes = axes.reshape(2, 1)\n",
    "    \n",
    "    # Plot original data in first row\n",
    "    ax = axes[0, 0]\n",
    "    make_nice_map(ax)\n",
    "    \n",
    "    # Original NO2 data\n",
    "    contour = ax.contourf(\n",
    "        datatree[\"geolocation/longitude\"],\n",
    "        datatree[\"geolocation/latitude\"], \n",
    "        da.where(datatree[\"product/main_data_quality_flag\"] == 0),\n",
    "        levels=50,\n",
    "        vmin=0,\n",
    "        zorder=2\n",
    "    )\n",
    "    ax.set_title('Original TEMPO NO₂ Data', fontsize=12)\n",
    "    \n",
    "    # Plot forecasts for selected days\n",
    "    forecast_days = [0, len(forecasts)//2, -1] if len(forecasts) >= 3 else list(range(min(len(forecasts), num_days)))\n",
    "    \n",
    "    for i, day_idx in enumerate(forecast_days[:num_days]):\n",
    "        if i > 0:  # Skip first column for original data\n",
    "            ax = axes[0, i]\n",
    "            ax.text(0.5, 0.5, 'Original\\nData\\nReference', ha='center', va='center', \n",
    "                   transform=ax.transAxes, fontsize=14, bbox=dict(boxstyle=\"round\", facecolor='lightgray'))\n",
    "            ax.set_xticks([])\n",
    "            ax.set_yticks([])\n",
    "        \n",
    "        # Forecast map in second row\n",
    "        ax = axes[1, i]\n",
    "        make_nice_map(ax)\n",
    "        \n",
    "        forecast_data = forecasts[day_idx]\n",
    "        \n",
    "        # Create a grid for interpolation\n",
    "        lon_grid = np.linspace(forecast_data['longitude'].min(), forecast_data['longitude'].max(), 50)\n",
    "        lat_grid = np.linspace(forecast_data['latitude'].min(), forecast_data['latitude'].max(), 50)\n",
    "        lon_mesh, lat_mesh = np.meshgrid(lon_grid, lat_grid)\n",
    "        \n",
    "        # Interpolate forecast data to grid\n",
    "        from scipy.interpolate import griddata\n",
    "        points = forecast_data[['longitude', 'latitude']].values\n",
    "        values = forecast_data['predicted_no2'].values\n",
    "        \n",
    "        grid_values = griddata(points, values, (lon_mesh, lat_mesh), method='linear')\n",
    "        \n",
    "        contour = ax.contourf(lon_mesh, lat_mesh, grid_values, \n",
    "                             levels=50, vmin=0, zorder=2)\n",
    "        \n",
    "        forecast_date = forecast_data['forecast_date'].iloc[0]\n",
    "        ax.set_title(f'Day +{day_idx+1} Forecast\\\\n{forecast_date.strftime(\"%Y-%m-%d\")}', fontsize=12)\n",
    "    \n",
    "    # Add colorbar\n",
    "    cbar = plt.colorbar(contour, ax=axes, shrink=0.8, aspect=30)\n",
    "    cbar.set_label('NO₂ Vertical Column (molecules/cm²)', fontsize=12)\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
