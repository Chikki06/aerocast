    "# Function to fetch multiple TEMPO granules for time series analysis\n",
    "def fetch_tempo_data_series(start_date, end_date, max_granules=10):\n",
    "    \"\"\"\n",
    "    Fetch a series of TEMPO data for time series analysis\n",
    "    This is a simplified version - in practice you'd want to iterate through available granules\n",
    "    \"\"\"\n",
    "    # For demonstration, we'll simulate multiple time points using the existing data\n",
    "    # In a real scenario, you'd fetch multiple granules across different dates\n",
    "    \n",
    "    print(f\"Simulating data series from {start_date} to {end_date}\")\n",
    "    print(\"Note: This demo uses the same spatial data with simulated temporal variations\")\n",
    "    \n",
    "    # Create a list to store our time series data\n",
    "    time_series_data = []\n",
    "    \n",
    "    # Extract key atmospheric variables\n",
    "    no2_data = datatree[\"product/vertical_column_troposphere\"]\n",
    "    quality_flag = datatree[\"product/main_data_quality_flag\"]\n",
    "    \n",
    "    # Get valid data points (quality flag == 0)\n",
    "    valid_mask = quality_flag == 0\n",
    "    valid_no2 = no2_data.where(valid_mask)\n",
    "    \n",
    "    # For each time point, create slightly varied data to simulate temporal changes\n",
    "    dates = pd.date_range(start_date, end_date, freq='D')[:max_granules]\n",
    "    \n",
    "    for i, date in enumerate(dates):\n",
    "        # Add some temporal variation (this is simulated for demo purposes)\n",
    "        variation_factor = 0.8 + 0.4 * np.random.random()  # Random factor between 0.8 and 1.2\n",
    "        seasonal_factor = 1 + 0.3 * np.sin(2 * np.pi * i / 365.25)  # Seasonal variation\n",
    "        \n",
    "        modified_no2 = valid_no2 * variation_factor * seasonal_factor\n",
    "        \n",
    "        # Store data for this time point\n",
    "        time_series_data.append({\n",
    "            'date': date,\n",
    "            'no2_data': modified_no2,\n",
    "            'longitude': longitude,\n",
    "            'latitude': latitude\n",
    "        })\n",
    "    \n",
    "    return time_series_data\n",
    "\n",
    "# Generate time series data\n",
    "start_date = '2024-01-01'\n",
    "end_date = '2024-01-10'\n",
    "time_series = fetch_tempo_data_series(start_date, end_date)\n",
    "\n",
    "print(f\"Generated {len(time_series)} time points for analysis\")"
   ]
  },
