    "# Quick Test - Run a Simple Prediction Demo\n",
    "# This works even if the full pipeline hasn't been executed yet\n",
    "\n",
    "print(\"=== QUICK PREDICTION DEMO ===\")\n",
    "print(\"(This demonstrates the prediction concept without requiring the full trained model)\\n\")\n",
    "\n",
    "# Create a simple mock prediction function for demonstration\n",
    "def mock_predict_atmospheric_conditions(test_data):\n",
    "    \"\"\"\n",
    "    Mock prediction function for demonstration purposes\n",
    "    \"\"\"\n",
    "    predictions = []\n",
    "    \n",
    "    for _, row in test_data.iterrows():\n",
    "        # Simple heuristic based on location and seasonal factors\n",
    "        base_pollution = 1.2e16  # Base NO2 level\n",
    "        \n",
    "        # Urban areas tend to have higher pollution\n",
    "        urban_factor = 1.0\n",
    "        if abs(row['longitude'] + 74) < 2 and abs(row['latitude'] - 40.7) < 2:  # NYC area\n",
    "            urban_factor = 1.8\n",
    "        elif abs(row['longitude'] + 118.2) < 2 and abs(row['latitude'] - 34.1) < 2:  # LA area\n",
    "            urban_factor = 1.6\n",
    "        elif abs(row['longitude'] + 87.6) < 2 and abs(row['latitude'] - 41.9) < 2:  # Chicago area\n",
    "            urban_factor = 1.4\n",
    "        \n",
    "        # Seasonal factor (winter months typically have higher NO2)\n",
    "        seasonal_factor = 1.2 if row['month'] in [12, 1, 2] else 0.9\n",
    "        \n",
    "        # Add some realistic variation\n",
    "        noise_factor = 0.8 + 0.4 * np.random.random()\n",
    "        \n",
    "        prediction = base_pollution * urban_factor * seasonal_factor * noise_factor\n",
    "        predictions.append(prediction)\n",
    "    \n",
    "    return np.array(predictions)\n",
    "\n",
    "# Run the quick demo\n",
    "print(\"🔄 Creating sample data...\")\n",
    "demo_data = create_sample_test_data()\n",
    "\n",
    "print(\"🔮 Running mock predictions...\")\n",
    "demo_predictions = mock_predict_atmospheric_conditions(demo_data)\n",
    "\n",
    "print(\"\\n📊 DEMO RESULTS:\")\n",
    "print(\"-\" * 40)\n",
    "\n",
    "cities = ['New York', 'Los Angeles', 'Chicago', 'Houston']\n",
    "for i, (city, prediction) in enumerate(zip(cities, demo_predictions)):\n",
    "    row = demo_data.iloc[i]\n",
    "    print(f\"🏙️  {city}\")\n",
    "    print(f\"   Location: ({row['longitude']:.1f}°, {row['latitude']:.1f}°)\")\n",
    "    print(f\"   Mock Prediction: {prediction:.2e} molecules/cm²\")\n",
    "    \n",
    "    # Classification\n",
    "    if prediction > 2e16:\n",
    "        status = \"⚠️  High\"\n",
    "    elif prediction > 1.2e16:\n",
    "        status = \"🟡 Moderate\"\n",
    "    else:\n",
    "        status = \"✅ Low\"\n",
    "    \n",
    "    print(f\"   Pollution Level: {status}\")\n",
    "    print()\n",
    "\n",
    "print(\"💡 This demonstrates the structure of predictions.\")\n",
    "print(\"   For real predictions, execute all training cells first, then run:\")\n",
    "print(\"   test_results = run_full_prediction_test()\")\n",
    "\n",
    "# Create a simple visualization\n",
    "fig, ax = plt.subplots(figsize=(10, 6))\n",
    "\n",
    "x_pos = np.arange(len(cities))\n",
    "bars = ax.bar(x_pos, demo_predictions, \n",
    "              color=['red', 'orange', 'yellow', 'green'],\n",
    "              alpha=0.7, edgecolor='black')\n",
    "\n",
    "ax.set_xlabel('Cities')\n",
    "ax.set_ylabel('NO₂ Concentration (molecules/cm²)')\n",
    "ax.set_title('Mock NO₂ Predictions for Major US Cities')\n",
    "ax.set_xticks(x_pos)\n",
    "ax.set_xticklabels(cities, rotation=45)\n",
    "\n",
    "# Add value labels on bars\n",
    "for bar, prediction in zip(bars, demo_predictions):\n",
    "    height = bar.get_height()\n",
    "    ax.text(bar.get_x() + bar.get_width()/2., height,\n",
    "            f'{prediction:.1e}',\n",
    "            ha='center', va='bottom', rotation=90, fontsize=9)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(\"\\n✅ Quick demo completed! Ready for full model testing once trained.\")"
