    "# Save model and create prediction function for future use\n",
    "import pickle\n",
    "from datetime import datetime\n",
    "\n",
    "def save_forecasting_system():\n",
    "    \"\"\"\n",
    "    Save the trained model and preprocessing components for future use\n",
    "    \"\"\"\n",
    "    best_model_name = max(model_results.keys(), key=lambda k: model_results[k]['r2'])\n",
    "    best_model_info = model_results[best_model_name]\n",
    "    \n",
    "    forecasting_system = {\n",
    "        'model': best_model_info['model'],\n",
    "        'scaler': best_model_info['scaler'],\n",
    "        'feature_columns': feature_columns,\n",
    "        'model_name': best_model_name,\n",
    "        'performance': {\n",
    "            'r2': best_model_info['r2'],\n",
    "            'mse': best_model_info['mse']\n",
    "        },\n",
    "        'created_date': datetime.now()\n",
    "    }\n",
    "    \n",
    "    # Save to file\n",
    "    with open('/tmp/tempo_forecasting_model.pkl', 'wb') as f:\n",
    "        pickle.dump(forecasting_system, f)\n",
    "    \n",
    "    print(f\"Forecasting system saved successfully!\")\n",
    "    print(f\"Model: {best_model_name}\")\n",
    "    print(f\"Performance: R² = {best_model_info['r2']:.4f}\")\n",
    "    print(f\"File: /tmp/tempo_forecasting_model.pkl\")\n",
    "    \n",
    "    return forecasting_system\n",
    "\n",
    "# Function to make new predictions\n",
    "def predict_atmospheric_conditions(new_data, forecasting_system):\n",
    "    \"\"\"\n",
    "    Make predictions using the saved forecasting system\n",
    "    \n",
    "    Parameters:\n",
    "    new_data: DataFrame with columns matching the training features\n",
    "    forecasting_system: The saved model system\n",
    "    \"\"\"\n",
    "    model = forecasting_system['model']\n",
    "    scaler = forecasting_system['scaler']\n",
    "    feature_cols = forecasting_system['feature_columns']\n",
    "    \n",
    "    # Prepare features\n",
    "    X_new = new_data[feature_cols]\n",
    "    \n",
    "    # Scale if necessary\n",
    "    if scaler is not None:\n",
    "        X_new_scaled = scaler.transform(X_new)\n",
    "        predictions = model.predict(X_new_scaled)\n",
    "    else:\n",
    "        predictions = model.predict(X_new)\n",
    "    \n",
    "    return predictions\n",
    "\n",
    "# Save the system\n",
    "saved_system = save_forecasting_system()\n",
    "\n",
    "print(\"\\\\nForecasting system ready for operational use!\")\n",
    "print(\"Use the predict_atmospheric_conditions() function for new predictions.\")"
   ]
  },
