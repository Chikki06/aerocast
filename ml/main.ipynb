    "# Future forecasting function\n",
    "def forecast_atmospheric_conditions(models, feature_cols, forecast_days=7):\n",
    "    \"\"\"\n",
    "    Generate future forecasts for atmospheric conditions\n",
    "    \"\"\"\n",
    "    print(f\"Generating {forecast_days}-day forecast...\")\n",
    "    \n",
    "    # Get the best performing model\n",
    "    best_model_name = max(model_results.keys(), key=lambda k: model_results[k]['r2'])\n",
    "    best_model_info = model_results[best_model_name]\n",
    "    best_model = best_model_info['model']\n",
    "    scaler = best_model_info['scaler']\n",
    "    \n",
    "    print(f\"Using {best_model_name} (R² = {best_model_info['r2']:.4f})\")\n",
    "    \n",
    "    # Get the latest data point for each location\n",
    "    latest_data = df_clean.sort_values('date').groupby(['latitude', 'longitude']).tail(1)\n",
    "    \n",
    "    forecasts = []\n",
    "    current_date = df_clean['date'].max()\n",
    "    \n",
    "    for day in range(1, forecast_days + 1):\n",
    "        forecast_date = current_date + timedelta(days=day)\n",
    "        \n",
    "        # Create features for the forecast date\n",
    "        forecast_features = latest_data.copy()\n",
    "        forecast_features['date'] = forecast_date\n",
    "        forecast_features['day_of_year'] = forecast_date.dayofyear\n",
    "        forecast_features['month'] = forecast_date.month\n",
    "        forecast_features['day_of_week'] = forecast_date.weekday()\n",
    "        forecast_features['sin_day_of_year'] = np.sin(2 * np.pi * forecast_date.dayofyear / 365.25)\n",
    "        forecast_features['cos_day_of_year'] = np.cos(2 * np.pi * forecast_date.dayofyear / 365.25)\n",
    "        \n",
    "        # Use the previous day's prediction as lag features\n",
    "        if day == 1:\n",
    "            forecast_features['no2_lag1'] = forecast_features['no2']\n",
    "            forecast_features['no2_lag2'] = forecast_features['no2_lag1']\n",
    "        else:\n",
    "            # Use previous forecasts as lag features\n",
    "            prev_forecast = forecasts[-1]\n",
    "            forecast_features['no2_lag1'] = prev_forecast['predicted_no2'].values\n",
    "            if day > 1:\n",
    "                forecast_features['no2_lag2'] = forecasts[-2]['predicted_no2'].values if len(forecasts) > 1 else prev_forecast['predicted_no2'].values\n",
    "        \n",
    "        # Update rolling statistics (simplified)\n",
    "        forecast_features['no2_rolling_mean'] = (forecast_features['no2'] + forecast_features['no2_lag1']) / 2\n",
    "        forecast_features['no2_rolling_std'] = np.abs(forecast_features['no2'] - forecast_features['no2_lag1']) / 2\n",
    "        \n",
    "        # Make predictions\n",
    "        X_forecast = forecast_features[feature_cols]\n",
    "        \n",
    "        if scaler is not None:\n",
    "            X_forecast_scaled = scaler.transform(X_forecast)\n",
    "            predictions = best_model.predict(X_forecast_scaled)\n",
    "        else:\n",
    "            predictions = best_model.predict(X_forecast)\n",
    "        \n",
    "        # Store forecast\n",
    "        forecast_df = forecast_features[['longitude', 'latitude']].copy()\n",
    "        forecast_df['predicted_no2'] = predictions\n",
    "        forecast_df['forecast_date'] = forecast_date\n",
    "        forecast_df['forecast_day'] = day\n",
    "        \n",
    "        forecasts.append(forecast_df)\n",
    "    \n",
    "    return forecasts, best_model_name\n",
    "\n",
    "# Generate forecasts\n",
    "forecasts, best_model_name = forecast_atmospheric_conditions(model_results, feature_columns)\n",
    "\n",
    "print(f\"Generated forecasts for {len(forecasts)} days using {best_model_name}\")\n",
    "print(f\"Each forecast contains {len(forecasts[0])} spatial points\")"
   ]
