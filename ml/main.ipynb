    "# Prepare data for machine learning\n",
    "def prepare_ml_data(time_series):\n",
    "    \"\"\"\n",
    "    Convert time series atmospheric data into a format suitable for machine learning\n",
    "    \"\"\"\n",
    "    ml_data = []\n",
    "    \n",
    "    for entry in time_series:\n",
    "        date = entry['date']\n",
    "        no2_data = entry['no2_data']\n",
    "        lon_data = entry['longitude']\n",
    "        lat_data = entry['latitude']\n",
    "        \n",
    "        # Flatten the 2D arrays and create features\n",
    "        valid_indices = ~np.isnan(no2_data.values)\n",
    "        \n",
    "        if np.any(valid_indices):\n",
    "            flat_no2 = no2_data.values[valid_indices]\n",
    "            flat_lon = lon_data.values[valid_indices]\n",
    "            flat_lat = lat_data.values[valid_indices]\n",
    "            \n",
    "            # Create temporal features\n",
    "            day_of_year = date.dayofyear\n",
    "            month = date.month\n",
    "            day_of_week = date.weekday()\n",
    "            \n",
    "            # For each valid data point, create a row\n",
    "            for i in range(len(flat_no2)):\n",
    "                ml_data.append({\n",
    "                    'date': date,\n",
    "                    'longitude': flat_lon[i],\n",
    "                    'latitude': flat_lat[i],\n",
    "                    'no2': flat_no2[i],\n",
    "                    'day_of_year': day_of_year,\n",
    "                    'month': month,\n",
    "                    'day_of_week': day_of_week,\n",
    "                    'sin_day_of_year': np.sin(2 * np.pi * day_of_year / 365.25),\n",
    "                    'cos_day_of_year': np.cos(2 * np.pi * day_of_year / 365.25)\n",
    "                })\n",
    "    \n",
    "    return pd.DataFrame(ml_data)\n",
    "\n",
    "# Convert to DataFrame\n",
    "df = prepare_ml_data(time_series)\n",
    "print(f\"Prepared dataset shape: {df.shape}\")\n",
    "print(f\"Columns: {list(df.columns)}\")\n",
    "print(f\"\\nFirst few rows:\")\n",
    "print(df.head())"
   ]
  },
