    "# Train predictive models\n",
    "def train_atmospheric_models(df_clean):\n",
    "    \"\"\"\n",
    "    Train multiple models to predict NO2 concentrations\n",
    "    \"\"\"\n",
    "    # Prepare features and target\n",
    "    feature_cols = [col for col in df_clean.columns if col not in ['date', 'no2']]\n",
    "    X = df_clean[feature_cols]\n",
    "    y = df_clean['no2']\n",
    "    \n",
    "    # Split data chronologically (earlier dates for training, later for testing)\n",
    "    df_sorted = df_clean.sort_values('date')\n",
    "    split_idx = int(0.8 * len(df_sorted))\n",
    "    \n",
    "    X_train = df_sorted[feature_cols].iloc[:split_idx]\n",
    "    X_test = df_sorted[feature_cols].iloc[split_idx:]\n",
    "    y_train = df_sorted['no2'].iloc[:split_idx]\n",
    "    y_test = df_sorted['no2'].iloc[split_idx:]\n",
    "    \n",
    "    # Scale features\n",
    "    scaler = StandardScaler()\n",
    "    X_train_scaled = scaler.fit_transform(X_train)\n",
    "    X_test_scaled = scaler.transform(X_test)\n",
    "    \n",
    "    # Train multiple models\n",
    "    models = {\n",
    "        'Linear Regression': LinearRegression(),\n",
    "        'Random Forest': RandomForestRegressor(n_estimators=100, random_state=42),\n",
    "    }\n",
    "    \n",
    "    results = {}\n",
    "    \n",
    "    for name, model in models.items():\n",
    "        print(f\"Training {name}...\")\n",
    "        \n",
    "        # Train model\n",
    "        if name == 'Linear Regression':\n",
    "            model.fit(X_train_scaled, y_train)\n",
    "            y_pred = model.predict(X_test_scaled)\n",
    "        else:\n",
    "            model.fit(X_train, y_train)\n",
    "            y_pred = model.predict(X_test)\n",
    "        \n",
    "        # Calculate metrics\n",
    "        mse = mean_squared_error(y_test, y_pred)\n",
    "        r2 = r2_score(y_test, y_pred)\n",
    "        \n",
    "        results[name] = {\n",
    "            'model': model,\n",
    "            'scaler': scaler if name == 'Linear Regression' else None,\n",
    "            'mse': mse,\n",
    "            'r2': r2,\n",
    "            'predictions': y_pred,\n",
    "            'actual': y_test\n",
    "        }\n",
    "        \n",
    "        print(f\"  MSE: {mse:.2e}\")\n",
    "        print(f\"  R²: {r2:.4f}\")\n",
    "    \n",
    "    return results, feature_cols\n",
    "\n",
    "# Train models\n",
    "model_results, feature_columns = train_atmospheric_models(df_clean)\n",
    "\n",
    "print(f\"\\nModel Performance Summary:\")\n",
    "for name, result in model_results.items():\n",
    "    print(f\"{name}: R² = {result['r2']:.4f}, MSE = {result['mse']:.2e}\")"
   ]
  },
