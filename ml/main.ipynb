    "# Feature engineering and model preparation\n",
    "def create_spatial_temporal_features(df):\n",
    "    \"\"\"\n",
    "    Create additional features for better prediction\n",
    "    \"\"\"\n",
    "    df_features = df.copy()\n",
    "    \n",
    "    # Spatial features\n",
    "    df_features['lat_lon_interaction'] = df_features['latitude'] * df_features['longitude']\n",
    "    df_features['distance_from_equator'] = np.abs(df_features['latitude'])\n",
    "    df_features['coastal_proximity'] = np.minimum(\n",
    "        np.abs(df_features['longitude'] + 100),  # Distance from Atlantic coast (approx)\n",
    "        np.abs(df_features['longitude'] + 120)   # Distance from Pacific coast (approx)\n",
    "    )\n",
    "    \n",
    "    # Temporal lag features (using shifted values from previous time steps)\n",
    "    df_features = df_features.sort_values(['latitude', 'longitude', 'date']).reset_index(drop=True)\n",
    "    df_features['no2_lag1'] = df_features.groupby(['latitude', 'longitude'])['no2'].shift(1)\n",
    "    df_features['no2_lag2'] = df_features.groupby(['latitude', 'longitude'])['no2'].shift(2)\n",
    "    \n",
    "    # Rolling statistics - Fix the index issue\n",
    "    rolling_mean = df_features.groupby(['latitude', 'longitude'])['no2'].rolling(window=3, min_periods=1).mean()\n",
    "    rolling_std = df_features.groupby(['latitude', 'longitude'])['no2'].rolling(window=3, min_periods=1).std()\n",
    "    \n",
    "    # Reset the MultiIndex to match the original DataFrame index\n",
    "    df_features['no2_rolling_mean'] = rolling_mean.values\n",
    "    df_features['no2_rolling_std'] = rolling_std.values\n",
    "    \n",
    "    return df_features\n",
    "\n",
    "# Create enhanced features\n",
    "df_features = create_spatial_temporal_features(df)\n",
    "\n",
    "# Remove rows with NaN values (from lag features)\n",
    "df_clean = df_features.dropna()\n",
    "\n",
    "print(f\"Enhanced dataset shape: {df_clean.shape}\")\n",
    "print(f\"Features: {[col for col in df_clean.columns if col not in ['date', 'no2']]}\")\n",
    "print(f\"\\nSample of enhanced data:\")\n",
    "print(df_clean[['longitude', 'latitude', 'no2', 'no2_lag1', 'no2_rolling_mean']].head())"
   ]
  },
